import "./assets/font/Rajdhani-Medium.ttf";
import "./assets/font/BarlowCondensed-Medium.ttf";
import { ScrollView } from "std-widgets.slint";

struct WifiNetwork {
    ssid: string,
    signal: int,
    secured: bool,
}

export component AppWindow inherits Window {
    full-screen: true;
    preferred-width: 1280px;
    preferred-height: 720px;
    background: #000000;

    in property <bool> force_compact_mode: false;
    in property <bool> compact_mode: self.force_compact_mode || self.width <= 700px || self.height <= 500px;
    in property <length> control_strip_width: self.compact_mode ? 0px : 140px;
    in property <length> overlay_margin: self.compact_mode ? 8px : 15px;
    in property <length> viewfinder_width: self.width - self.control_strip_width;

    in property <image> camera_feed;
    in-out property <bool> is_recording: false;
    in-out property <bool> record_busy: false;
    in-out property <float> record_busy_pulse: 0.0;
    in-out property <bool> media_open: false;
    in-out property <bool> media_loading: false;
    in-out property <float> media_loading_pulse: 0.0;
    in-out property <bool> delete_confirm_open: false;
    in-out property <bool> grid_visible: true;
    in-out property <bool> focus_peaking_visible: false;
    in-out property <bool> zoom_magnifier_visible: false;
    in-out property <int> exposure_signal: 0;
    in-out property <bool> exposure_overlay_visible: false;
    in-out property <[string]> media_clip_rows: [];
    in-out property <[string]> media_clip_durations: [];
    in-out property <[image]> media_clip_thumbs: [];
    in-out property <int> media_selected_index: -1;
    in-out property <string> media_selected_name: "No clip selected";
    in-out property <string> media_selected_detail: "Open Media to browse recordings";
    in-out property <bool> settings_open: false;
    in-out property <bool> full_auto: false;
    in-out property <int> selected_setting: 0;
    in-out property <string> timecode: "00:00:00:00";
    in-out property <string> selected_setting_label: "FPS";
    in-out property <string> selected_setting_prev_value: "25";
    in-out property <string> selected_setting_value: "30";
    in-out property <string> selected_setting_next_value: "50";

    in-out property <string> current_fps: "30";
    in-out property <string> current_shutter: "180°";
    in-out property <string> current_iso: "100";
    in-out property <string> current_wb: "Auto";
    in-out property <string> current_record_format: "MP4";
    in-out property <string> current_resolution: "720p";
    in-out property <string> current_aspect_ratio: "16:9";
    in-out property <string> current_tint: "0";
    in-out property <string> current_mode_label: "M";
    in-out property <string> current_media_status: "READY";
    in-out property <string> current_media_detail: "MP4 ready";
    in-out property <float> audio_level_left: 0.0;
    in-out property <float> audio_level_right: 0.0;
    in-out property <float> audio_peak_left: 0.0;
    in-out property <float> audio_peak_right: 0.0;
    in-out property <bool> audio_clip_left: false;
    in-out property <bool> audio_clip_right: false;

    in-out property <bool> system_open: false;
    in-out property <int> system_tab_index: 0;
    in-out property <float> backlight_level: 0.5;
    in-out property <[string]> audio_devices: [];
    in-out property <int> audio_device_index: 0;
    in-out property <float> audio_gain: 0.8;
    in-out property <string> storage_used: "--";
    in-out property <string> storage_total: "--";
    in-out property <float> storage_percent: 0.0;
    in-out property <string> network_interface: "--";
    in-out property <string> network_type: "--";
    in-out property <string> network_ip: "--";
    in-out property <string> network_gateway: "--";
    in-out property <string> network_ssid: "--";
    in-out property <string> cpu_temp: "--";
    in-out property <string> system_uptime: "--";
    in-out property <string> system_confirm_action: "";
    in-out property <bool> system_confirm_open: false;
    in-out property <string> system_model: "Raspberry Pi 5";
    in-out property <string> system_version: "lumapi-cam v2.1.0";
    in-out property <bool> screen_blanked: false;
    in-out property <int> display_timeout_index: 0;

    in-out property <bool> wifi_scanning: false;
    in-out property <[WifiNetwork]> wifi_networks: [];
    in-out property <string> wifi_selected_ssid: "";
    in-out property <string> wifi_typed_password: "";
    in-out property <bool> wifi_keyboard_open: false;
    in-out property <bool> wifi_keyboard_symbols: false;
    in-out property <bool> wifi_keyboard_shift: false;
    in-out property <bool> wifi_connecting: false;
    in-out property <string> wifi_connection_error: "";
    in-out property <int> network_sub_tab: 0;

    callback toggle_record();
    callback toggle_settings();
    callback toggle_full_auto();
    callback select_setting(int);
    callback adjust_setting(int);
    callback toggle_media();
    callback media_select(int);
    callback media_play(int);
    callback media_refresh();
    callback media_delete_selected();
    callback toggle_focus_peaking();
    callback toggle_system();
    callback system_select_tab(int);
    callback set_backlight(float);
    callback select_audio_device(int);
    callback set_audio_gain(float);
    callback delete_all_recordings();
    callback system_shutdown();
    callback system_reboot();
    callback display_set_timeout(int);
    callback interaction_occurred();
    callback wifi_scan();
    callback wifi_connect(string, string);
    callback wifi_type_key(string);
    callback wifi_backspace();

    Rectangle {
        x: 0;
        y: 0;
        width: root.viewfinder_width;
        height: root.height;
        background: #111111;
        clip: true;

        Image {
            x: root.zoom_magnifier_visible ? -parent.width / 2 : 0px;
            y: root.zoom_magnifier_visible ? -parent.height / 2 : 0px;
            width: root.zoom_magnifier_visible ? 200% : 100%;
            height: root.zoom_magnifier_visible ? 200% : 100%;
            source: root.camera_feed;
            image-fit: fill;
        }

        // Viewfinder Grid Lines (toggleable)
        if (root.grid_visible) : Rectangle {
            x: 0;
            y: 0;
            width: 100%;
            height: 100%;
            Rectangle { x: parent.width * 0.333; y: 0; width: 1px; height: 100%; background: rgba(255, 255, 255, 0.15); }
            Rectangle { x: parent.width * 0.666; y: 0; width: 1px; height: 100%; background: rgba(255, 255, 255, 0.15); }
            Rectangle { x: 0; y: parent.height * 0.333; width: 100%; height: 1px; background: rgba(255, 255, 255, 0.15); }
            Rectangle { x: 0; y: parent.height * 0.666; width: 100%; height: 1px; background: rgba(255, 255, 255, 0.15); }

            // Center Crosshair
            Rectangle { x: parent.width / 2 - 8px; y: parent.height / 2 - 1px; width: 16px; height: 1px; background: rgba(255, 255, 255, 0.4); }
            Rectangle { x: parent.width / 2 - 1px; y: parent.height / 2 - 8px; width: 1px; height: 16px; background: rgba(255, 255, 255, 0.4); }
    }

    Rectangle {
        visible: root.compact_mode && root.system_open;
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;
        background: #0a0c10;

        VerticalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 12px;

            // Header Bar
            Rectangle {
                width: 100%;
                height: 56px;
                background: transparent;

                HorizontalLayout {
                    alignment: space-between;

                    TouchArea {
                        width: 48px;
                        height: 48px;
                        clicked => { root.toggle_system(); }
                        Rectangle {
                            width: 100%;
                            height: 100%;
                            border-radius: 24px;
                            background: rgba(255, 255, 255, 0.08);
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.15);
                            Text { text: "✕"; font-size: 20px; font-weight: 800; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "SYSTEM SETTINGS";
                            font-size: 20px;
                            font-weight: 800;
                            color: #ffffff;
                            font-family: "Rajdhani";
                            horizontal-alignment: center;
                        }
                    }

                    Rectangle { width: 48px; height: 48px; background: transparent; }
                }
            }

            // Body: Tab Strip + Content
            HorizontalLayout {
                width: 100%;
                height: root.height - 92px;
                spacing: 8px;

                // Left Tab Strip
                Rectangle {
                    width: 72px;
                    height: 100%;
                    background: rgba(0, 0, 0, 0.30);
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: rgba(255, 255, 255, 0.06);

                    VerticalLayout {
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 2px;
                        alignment: center;

                        for idx in [0, 1, 2, 3, 4] : TouchArea {
                            width: 60px;
                            height: 52px;
                            clicked => { root.system_select_tab(idx); }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                border-radius: 6px;
                                background: root.system_tab_index == idx ? rgba(255, 59, 48, 0.18) : transparent;
                                border-width: 1px;
                                border-color: root.system_tab_index == idx ? #ff3b30 : transparent;

                                // Display tab icon (Screen + stand)
                                if (idx == 0) : Rectangle {
                                    width: 24px;
                                    height: 22px;
                                    Rectangle {
                                        x: 0;
                                        y: 0;
                                        width: 24px;
                                        height: 17px;
                                        border-radius: 2px;
                                        border-width: 2px;
                                        border-color: root.system_tab_index == idx ? #ff5c5c : #888888;
                                        background: transparent;
                                    }
                                    Rectangle {
                                        x: 10px;
                                        y: 17px;
                                        width: 4px;
                                        height: 3px;
                                        background: root.system_tab_index == idx ? #ff5c5c : #888888;
                                    }
                                    Rectangle {
                                        x: 6px;
                                        y: 20px;
                                        width: 12px;
                                        height: 2px;
                                        background: root.system_tab_index == idx ? #ff5c5c : #888888;
                                        border-radius: 0.5px;
                                    }
                                }

                                // Audio tab icon (Speaker)
                                if (idx == 1) : Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    Path {
                                        width: 100%;
                                        height: 100%;
                                        stroke: root.system_tab_index == idx ? #ff5c5c : #888888;
                                        stroke-width: 1.8px;
                                        fill: root.system_tab_index == idx ? rgba(255, 92, 92, 0.15) : transparent;
                                        commands: "M 3 7 L 8 7 L 14 2 L 14 20 L 8 15 L 3 15 Z";
                                    }
                                }

                                // Storage tab icon (Floppy disk)
                                if (idx == 2) : Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    Rectangle {
                                        x: 1px;
                                        y: 1px;
                                        width: 20px;
                                        height: 20px;
                                        border-radius: 2px;
                                        border-width: 2px;
                                        border-color: root.system_tab_index == idx ? #ff5c5c : #888888;
                                        background: transparent;
                                    }
                                    Rectangle {
                                        x: 7px;
                                        y: 12px;
                                        width: 8px;
                                        height: 7px;
                                        border-radius: 1px;
                                        background: root.system_tab_index == idx ? #ff5c5c : #888888;
                                    }
                                    Rectangle {
                                        x: 7px;
                                        y: 3px;
                                        width: 8px;
                                        height: 5px;
                                        border-width: 1px;
                                        border-color: root.system_tab_index == idx ? #ff5c5c : #888888;
                                        background: transparent;
                                    }
                                }

                                // Network tab icon (4 Signal bars)
                                if (idx == 3) : Rectangle {
                                    width: 22px;
                                    height: 20px;
                                    Rectangle { x: 1px; y: 14px; width: 3.5px; height: 6px; background: root.system_tab_index == idx ? #ff5c5c : #888888; border-radius: 0.5px; }
                                    Rectangle { x: 6px; y: 10px; width: 3.5px; height: 10px; background: root.system_tab_index == idx ? #ff5c5c : #888888; border-radius: 0.5px; }
                                    Rectangle { x: 11px; y: 6px; width: 3.5px; height: 14px; background: root.system_tab_index == idx ? #ff5c5c : #888888; border-radius: 0.5px; }
                                    Rectangle { x: 16px; y: 2px; width: 3.5px; height: 18px; background: root.system_tab_index == idx ? #ff5c5c : #888888; border-radius: 0.5px; }
                                }

                                // System tab icon (CPU/Chip layout)
                                if (idx == 4) : Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    Rectangle {
                                        x: 5px;
                                        y: 5px;
                                        width: 12px;
                                        height: 12px;
                                        border-radius: 1px;
                                        border-width: 1.5px;
                                        border-color: root.system_tab_index == idx ? #ff5c5c : #888888;
                                    }
                                    Rectangle { x: 1px; y: 7px; width: 4px; height: 1.5px; background: root.system_tab_index == idx ? #ff5c5c : #888888; }
                                    Rectangle { x: 1px; y: 13px; width: 4px; height: 1.5px; background: root.system_tab_index == idx ? #ff5c5c : #888888; }
                                    Rectangle { x: 17px; y: 7px; width: 4px; height: 1.5px; background: root.system_tab_index == idx ? #ff5c5c : #888888; }
                                    Rectangle { x: 17px; y: 13px; width: 4px; height: 1.5px; background: root.system_tab_index == idx ? #ff5c5c : #888888; }
                                    Rectangle { x: 7px; y: 1px; width: 1.5px; height: 4px; background: root.system_tab_index == idx ? #ff5c5c : #888888; }
                                    Rectangle { x: 13px; y: 1px; width: 1.5px; height: 4px; background: root.system_tab_index == idx ? #ff5c5c : #888888; }
                                    Rectangle { x: 7px; y: 17px; width: 1.5px; height: 4px; background: root.system_tab_index == idx ? #ff5c5c : #888888; }
                                    Rectangle { x: 13px; y: 17px; width: 1.5px; height: 4px; background: root.system_tab_index == idx ? #ff5c5c : #888888; }
                                }
                            }
                        }
                    }
                }

                // Content Panel
                Rectangle {
                    height: 100%;
                    background: rgba(0, 0, 0, 0.20);
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: rgba(255, 255, 255, 0.06);
                    clip: true;

                    // --- Display Tab ---
                    if (root.system_tab_index == 0) : VerticalLayout {
                        padding: 16px;
                        spacing: 12px;
                        alignment: start;

                        Text {
                            text: "DISPLAY";
                            font-size: 22px;
                            font-weight: 800;
                            color: #ffffff;
                            font-family: "Rajdhani";
                        }

                        VerticalLayout {
                            spacing: 6px;
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle {
                                    width: 18px;
                                    height: 22px;
                                    Rectangle {
                                        y: (parent.height - 18px) / 2;
                                        width: 18px;
                                        height: 18px;
                                        Rectangle {
                                            x: 5px;
                                            y: 5px;
                                            width: 8px;
                                            height: 8px;
                                            border-radius: 4px;
                                            background: #b5bcc8;
                                        }
                                        Rectangle { x: 8px; y: 1px; width: 2px; height: 3px; background: #b5bcc8; border-radius: 0.5px; }
                                        Rectangle { x: 8px; y: 14px; width: 2px; height: 3px; background: #b5bcc8; border-radius: 0.5px; }
                                        Rectangle { x: 1px; y: 8px; width: 3px; height: 2px; background: #b5bcc8; border-radius: 0.5px; }
                                        Rectangle { x: 14px; y: 8px; width: 3px; height: 2px; background: #b5bcc8; border-radius: 0.5px; }
                                    }
                                }
                                Text { text: "SCREEN BRIGHTNESS"; font-size: 18px; font-weight: 800; color: #b5bcc8; font-family: "Rajdhani"; vertical-alignment: center; }
                            }
                            Rectangle {
                                width: 100%;
                                height: 48px;
                                border-radius: 8px;
                                background: rgba(255, 255, 255, 0.04);
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.08);

                                // Progress fill
                                Rectangle {
                                    x: 4px;
                                    y: 4px;
                                    width: (parent.width - 8px) * root.backlight_level;
                                    height: parent.height - 8px;
                                    border-radius: 6px;
                                    background: #10b981;
                                }

                                // Thumb/handle (vertical pill shape)
                                Rectangle {
                                    x: max(4px, min(parent.width - 20px, 4px + (parent.width - 8px) * root.backlight_level - 8px));
                                    y: (parent.height - 32px) / 2;
                                    width: 16px;
                                    height: 32px;
                                    border-radius: 8px;
                                    background: #ffffff;
                                    border-width: 2px;
                                    border-color: #10b981;
                                }

                                // Readout inside track
                                Text {
                                    text: round(root.backlight_level * 100) + "%";
                                    font-size: 16px;
                                    font-weight: 800;
                                    color: (4px + (parent.width - 8px) * root.backlight_level > parent.width - 64px) ? #054028 : #ffffff;
                                    font-family: "Rajdhani";
                                    x: parent.width - self.width - 16px;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                                    x: 0;
                                    y: 0;
                                    width: 100%;
                                    height: 100%;
                                    clicked => {
                                        let level = max(0, min(1, self.mouse-x / parent.width));
                                        root.backlight_level = level;
                                        root.set_backlight(level);
                                    }
                                    moved => {
                                        if (self.pressed) {
                                            let level = max(0, min(1, self.mouse-x / parent.width));
                                            root.backlight_level = level;
                                            root.set_backlight(level);
                                        }
                                    }
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 6px;
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle {
                                    width: 18px;
                                    height: 22px;
                                    Rectangle {
                                        y: (parent.height - 18px) / 2;
                                        width: 18px;
                                        height: 18px;
                                        Rectangle {
                                            width: 100%;
                                            height: 100%;
                                            border-radius: 9px;
                                            border-width: 2px;
                                            border-color: #b5bcc8;
                                        }
                                        Rectangle { x: 8px; y: 5px; width: 2px; height: 5px; background: #b5bcc8; border-radius: 0.5px; }
                                        Rectangle { x: 9px; y: 8px; width: 5px; height: 2px; background: #b5bcc8; border-radius: 0.5px; }
                                    }
                                }
                                Text { text: "SCREEN TIMEOUT"; font-size: 18px; font-weight: 800; color: #b5bcc8; font-family: "Rajdhani"; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                for timeout_label[idx] in ["Off", "1 min", "5 min", "10 min"] : TouchArea {
                                    height: 48px;
                                    clicked => {
                                        root.display_timeout_index = idx;
                                        root.display_set_timeout(idx);
                                    }
                                    Rectangle {
                                        width: 100%;
                                        height: 100%;
                                        border-radius: 6px;
                                        background: root.display_timeout_index == idx ? rgba(255, 59, 48, 0.18) : rgba(255, 255, 255, 0.04);
                                        border-width: 1px;
                                        border-color: root.display_timeout_index == idx ? #ff3b30 : rgba(255, 255, 255, 0.08);

                                        animate background { duration: 200ms; }
                                        animate border-color { duration: 200ms; }

                                        Text {
                                            text: timeout_label;
                                            font-size: 15px;
                                            font-weight: 800;
                                            color: root.display_timeout_index == idx ? #ff5c5c : #888888;
                                            font-family: "Rajdhani";
                                            horizontal-alignment: center;
                                            vertical-alignment: center;

                                            animate color { duration: 200ms; }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // --- Audio Tab ---
                    if (root.system_tab_index == 1) : VerticalLayout {
                        padding: 16px;
                        spacing: 12px;
                        alignment: start;

                        Text {
                            text: "AUDIO";
                            font-size: 22px;
                            font-weight: 800;
                            color: #ffffff;
                            font-family: "Rajdhani";
                        }

                        // Gain Section
                        VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle {
                                    width: 18px;
                                    height: 22px;
                                    // Slider control icon
                                    Rectangle {
                                        y: (parent.height - 12px) / 2;
                                        width: 18px;
                                        height: 12px;
                                        Rectangle { x: 1px; y: 5px; width: 16px; height: 2px; background: #b5bcc8; }
                                        Rectangle { x: 7px; y: 1px; width: 4px; height: 10px; background: #b5bcc8; border-radius: 1px; }
                                    }
                                }
                                Text { text: "GAIN"; font-size: 18px; font-weight: 800; color: #b5bcc8; font-family: "Rajdhani"; vertical-alignment: center; }
                            }
                            Rectangle {
                                width: 100%;
                                height: 48px;
                                border-radius: 8px;
                                background: rgba(255, 255, 255, 0.04);
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.08);

                                // Progress fill
                                Rectangle {
                                    x: 4px;
                                    y: 4px;
                                    width: (parent.width - 8px) * root.audio_gain;
                                    height: parent.height - 8px;
                                    border-radius: 6px;
                                    background: #4cd964;
                                }

                                // Thumb/handle (vertical pill shape)
                                Rectangle {
                                    x: max(4px, min(parent.width - 20px, 4px + (parent.width - 8px) * root.audio_gain - 8px));
                                    y: (parent.height - 32px) / 2;
                                    width: 16px;
                                    height: 32px;
                                    border-radius: 8px;
                                    background: #ffffff;
                                    border-width: 2px;
                                    border-color: #4cd964;
                                }

                                // Readout inside track
                                Text {
                                    text: round(root.audio_gain * 100) + "%";
                                    font-size: 16px;
                                    font-weight: 800;
                                    color: (4px + (parent.width - 8px) * root.audio_gain > parent.width - 64px) ? #023c10 : #ffffff;
                                    font-family: "Rajdhani";
                                    x: parent.width - self.width - 16px;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                                    x: 0;
                                    y: 0;
                                    width: 100%;
                                    height: 100%;
                                    clicked => {
                                        let gain = max(0, min(1, self.mouse-x / parent.width));
                                        root.audio_gain = gain;
                                        root.set_audio_gain(gain);
                                    }
                                    moved => {
                                        if (self.pressed) {
                                            let gain = max(0, min(1, self.mouse-x / parent.width));
                                            root.audio_gain = gain;
                                            root.set_audio_gain(gain);
                                        }
                                    }
                                }
                            }
                        }

                        // Live Level Monitor Section
                        VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle {
                                    width: 18px;
                                    height: 22px;
                                    // VU meter icon: 3 vertical bars of increasing height
                                    Rectangle {
                                        y: (parent.height - 14px) / 2;
                                        width: 18px;
                                        height: 14px;
                                        Rectangle { x: 2px; y: 8px; width: 3px; height: 6px; background: #b5bcc8; border-radius: 0.5px; }
                                        Rectangle { x: 7px; y: 4px; width: 3px; height: 10px; background: #b5bcc8; border-radius: 0.5px; }
                                        Rectangle { x: 12px; y: 0px; width: 3px; height: 14px; background: #b5bcc8; border-radius: 0.5px; }
                                    }
                                }
                                Text { text: "LIVE LEVEL MONITOR"; font-size: 18px; font-weight: 800; color: #b5bcc8; font-family: "Rajdhani"; vertical-alignment: center; }
                            }
                            
                            Rectangle {
                                width: 100%;
                                height: 64px;
                                background: rgba(0, 0, 0, 0.30);
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.06);

                                VerticalLayout {
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    spacing: 8px;
                                    alignment: center;

                                    // Left Channel VU Bar
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "L"; font-size: 14px; font-weight: 800; color: #888888; font-family: "Rajdhani"; vertical-alignment: center; width: 12px; }
                                        Rectangle {
                                            width: parent.width - 24px;
                                            height: 8px;
                                            background: rgba(255, 255, 255, 0.05);
                                            border-radius: 2px;
                                            clip: true;
                                            Rectangle {
                                                x: 0;
                                                y: 0;
                                                width: parent.width * root.audio_level_left;
                                                height: 100%;
                                                background: root.audio_clip_left ? #ff3b30 : root.audio_level_left >= 0.82 ? #ffcc00 : #4cd964;
                                            }
                                            Rectangle {
                                                x: parent.width * root.audio_peak_left - 1px;
                                                y: 0;
                                                width: 2px;
                                                height: 100%;
                                                background: #ffffff;
                                                visible: root.audio_peak_left > 0;
                                            }
                                        }
                                    }

                                    // Right Channel VU Bar
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "R"; font-size: 14px; font-weight: 800; color: #888888; font-family: "Rajdhani"; vertical-alignment: center; width: 12px; }
                                        Rectangle {
                                            width: parent.width - 24px;
                                            height: 8px;
                                            background: rgba(255, 255, 255, 0.05);
                                            border-radius: 2px;
                                            clip: true;
                                            Rectangle {
                                                x: 0;
                                                y: 0;
                                                width: parent.width * root.audio_level_right;
                                                height: 100%;
                                                background: root.audio_clip_right ? #ff3b30 : root.audio_level_right >= 0.82 ? #ffcc00 : #4cd964;
                                            }
                                            Rectangle {
                                                x: parent.width * root.audio_peak_right - 1px;
                                                y: 0;
                                                width: 2px;
                                                height: 100%;
                                                background: #ffffff;
                                                visible: root.audio_peak_right > 0;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // --- Storage Tab ---
                    if (root.system_tab_index == 2) : VerticalLayout {
                        padding: 16px;
                        spacing: 12px;
                        alignment: start;

                        Text {
                            text: "STORAGE";
                            font-size: 22px;
                            font-weight: 800;
                            color: #ffffff;
                            font-family: "Rajdhani";
                        }

                        VerticalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle {
                                    width: 18px;
                                    height: 22px;
                                    // 3-tier drive stack icon
                                    Rectangle {
                                        y: (parent.height - 15px) / 2;
                                        width: 18px;
                                        height: 15px;
                                        Rectangle { x: 3px; y: 0px; width: 12px; height: 3px; border-radius: 1px; border-width: 1.5px; border-color: #b5bcc8; }
                                        Rectangle { x: 3px; y: 5px; width: 12px; height: 3px; border-radius: 1px; border-width: 1.5px; border-color: #b5bcc8; }
                                        Rectangle { x: 3px; y: 10px; width: 12px; height: 3px; border-radius: 1px; border-width: 1.5px; border-color: #b5bcc8; }
                                    }
                                }
                                Text { text: "RECORDINGS STORAGE"; font-size: 18px; font-weight: 800; color: #b5bcc8; font-family: "Rajdhani"; vertical-alignment: center; }
                            }
                            Rectangle {
                                width: 100%;
                                height: 36px;
                                border-radius: 8px;
                                background: rgba(255, 255, 255, 0.04);
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.08);
                                clip: true;

                                // Progress fill
                                Rectangle {
                                    x: 0;
                                    y: 0;
                                    width: parent.width * root.storage_percent;
                                    height: 100%;
                                    border-radius: 6px;
                                    background: root.storage_percent > 0.85 ? #ff3b30 : root.storage_percent > 0.65 ? #ffcc00 : #4cd964;
                                }

                                // Segment lines overlay (10 divisions)
                                Rectangle { x: parent.width * 0.1; width: 1.5px; height: 100%; background: rgba(0, 0, 0, 0.2); }
                                Rectangle { x: parent.width * 0.2; width: 1.5px; height: 100%; background: rgba(0, 0, 0, 0.2); }
                                Rectangle { x: parent.width * 0.3; width: 1.5px; height: 100%; background: rgba(0, 0, 0, 0.2); }
                                Rectangle { x: parent.width * 0.4; width: 1.5px; height: 100%; background: rgba(0, 0, 0, 0.2); }
                                Rectangle { x: parent.width * 0.5; width: 1.5px; height: 100%; background: rgba(0, 0, 0, 0.2); }
                                Rectangle { x: parent.width * 0.6; width: 1.5px; height: 100%; background: rgba(0, 0, 0, 0.2); }
                                Rectangle { x: parent.width * 0.7; width: 1.5px; height: 100%; background: rgba(0, 0, 0, 0.2); }
                                Rectangle { x: parent.width * 0.8; width: 1.5px; height: 100%; background: rgba(0, 0, 0, 0.2); }
                                Rectangle { x: parent.width * 0.9; width: 1.5px; height: 100%; background: rgba(0, 0, 0, 0.2); }

                                // Embedded percentage text
                                Text {
                                    text: round(root.storage_percent * 100) + "% USED";
                                    font-size: 13px;
                                    font-weight: 800;
                                    color: (root.storage_percent > 0.88) ? #2b0000 : #ffffff;
                                    font-family: "Rajdhani";
                                    x: parent.width - self.width - 12px;
                                    vertical-alignment: center;
                                }
                            }
                            HorizontalLayout {
                                alignment: space-between;
                                Text { text: root.storage_used + " used"; font-size: 16px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; }
                                Text { text: root.storage_total + " total"; font-size: 16px; font-weight: 700; color: #888888; font-family: "Rajdhani"; }
                            }
                        }

                        TouchArea {
                            height: 56px;
                            enabled: !root.is_recording;
                            clicked => { root.system_confirm_action = "delete_all"; root.system_confirm_open = true; }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                border-radius: 8px;
                                background: root.is_recording ? rgba(255, 255, 255, 0.02) : rgba(255, 59, 48, 0.12);
                                border-width: 1px;
                                border-color: root.is_recording ? rgba(255, 255, 255, 0.08) : #ff3b30;

                                animate background { duration: 150ms; }
                                animate border-color { duration: 150ms; }

                                HorizontalLayout {
                                    alignment: center;
                                    spacing: 8px;

                                    // Trash can vector icon
                                    VerticalLayout {
                                        alignment: center;
                                        height: 100%;
                                        Rectangle {
                                            width: 18px;
                                            height: 18px;
                                            // Lid
                                            Rectangle {
                                                x: 3px;
                                                y: 2px;
                                                width: 12px;
                                                height: 2px;
                                                background: root.is_recording ? #888888 : #ff3b30;
                                                border-radius: 0.5px;

                                                animate background { duration: 150ms; }
                                            }
                                            // Lid handle
                                            Rectangle {
                                                x: 7px;
                                                y: 0px;
                                                width: 4px;
                                                height: 2px;
                                                background: root.is_recording ? #888888 : #ff3b30;
                                                border-radius: 0.5px;

                                                animate background { duration: 150ms; }
                                            }
                                            // Can body
                                            Rectangle {
                                                x: 4px;
                                                y: 5px;
                                                width: 10px;
                                                height: 11px;
                                                border-radius: 1px;
                                                border-width: 1.5px;
                                                border-color: root.is_recording ? #888888 : #ff3b30;

                                                animate border-color { duration: 150ms; }
                                            }
                                        }
                                    }

                                    Text {
                                        text: "DELETE ALL RECORDINGS";
                                        font-size: 16px;
                                        font-weight: 800;
                                        color: root.is_recording ? #888888 : #ff3b30;
                                        font-family: "Rajdhani";
                                        vertical-alignment: center;

                                        animate color { duration: 150ms; }
                                    }
                                }
                            }
                        }
                    }

                    // --- Network Tab ---
                    if (root.system_tab_index == 3) : VerticalLayout {
                        padding: 16px;
                        spacing: 12px;
                        alignment: start;

                        Text {
                            text: "NETWORK";
                            font-size: 22px;
                            font-weight: 800;
                            color: #ffffff;
                            font-family: "Rajdhani";
                        }

                        // Sub Tab Switcher
                        HorizontalLayout {
                            spacing: 8px;
                            height: 36px;
                            for sub_tab_name[idx] in ["STATUS", "WI-FI NETWORKS"] : TouchArea {
                                clicked => { root.network_sub_tab = idx; }
                                Rectangle {
                                    width: 100%;
                                    height: 100%;
                                    border-radius: 6px;
                                    background: root.network_sub_tab == idx ? rgba(255, 59, 48, 0.12) : rgba(255, 255, 255, 0.02);
                                    border-width: 1px;
                                    border-color: root.network_sub_tab == idx ? #ff3b30 : rgba(255, 255, 255, 0.06);

                                    animate background { duration: 150ms; }
                                    animate border-color { duration: 150ms; }

                                    Text {
                                        text: sub_tab_name;
                                        font-size: 14px;
                                        font-weight: 800;
                                        color: root.network_sub_tab == idx ? #ff5c5c : #888888;
                                        font-family: "Rajdhani";
                                        horizontal-alignment: center;
                                        vertical-alignment: center;

                                        animate color { duration: 150ms; }
                                    }
                                }
                            }
                        }

                        // --- Status Panel ---
                        if (root.network_sub_tab == 0) : VerticalLayout {
                            spacing: 10px;

                            // Interface Card
                            Rectangle {
                                width: 100%;
                                height: 60px;
                                border-radius: 8px;
                                background: rgba(255, 255, 255, 0.03);
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.06);
                                clip: true;

                                // Left accent line (Blue)
                                Rectangle {
                                    x: 0;
                                    y: 0;
                                    width: 4px;
                                    height: 100%;
                                    background: #5a5aff;
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 12px;
                                    padding-top: 6px;
                                    padding-bottom: 6px;
                                    spacing: 1px;
                                    alignment: center;
                                    Text { text: "INTERFACE"; font-size: 12px; font-weight: 800; color: #888888; font-family: "Rajdhani"; }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Text { text: root.network_interface; font-size: 17px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; vertical-alignment: center; }
                                        Rectangle {
                                            border-radius: 3px;
                                            background: root.network_type == "WiFi" ? rgba(16, 185, 129, 0.15) : rgba(90, 90, 255, 0.15);
                                            Text { text: root.network_type; font-size: 12px; font-weight: 700; color: root.network_type == "WiFi" ? #10b981 : #5a5aff; font-family: "Rajdhani"; x: 6px; y: 1px; }
                                        }
                                    }
                                }
                            }

                            // IP Address Card
                            Rectangle {
                                width: 100%;
                                height: 60px;
                                border-radius: 8px;
                                background: rgba(255, 255, 255, 0.03);
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.06);
                                clip: true;

                                // Left accent line (Green)
                                Rectangle {
                                    x: 0;
                                    y: 0;
                                    width: 4px;
                                    height: 100%;
                                    background: #10b981;
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 12px;
                                    padding-top: 6px;
                                    padding-bottom: 6px;
                                    spacing: 1px;
                                    alignment: center;
                                    HorizontalLayout {
                                        alignment: space-between;
                                        Text { text: "IP ADDRESS"; font-size: 12px; font-weight: 800; color: #888888; font-family: "Rajdhani"; }
                                        
                                        // Connection status badge
                                        HorizontalLayout {
                                            spacing: 4px;
                                            alignment: end;
                                            Rectangle {
                                                width: 6px;
                                                height: 6px;
                                                border-radius: 3px;
                                                background: (root.network_ip == "--" || root.network_ip == "") ? #ff3b30 : #10b981;
                                                y: (parent.height - 6px) / 2;
                                            }
                                            Text {
                                                text: (root.network_ip == "--" || root.network_ip == "") ? "DISCONNECTED" : "CONNECTED";
                                                font-size: 11px;
                                                font-weight: 800;
                                                color: (root.network_ip == "--" || root.network_ip == "") ? #ff5c5c : #10b981;
                                                font-family: "Rajdhani";
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                    Text { text: root.network_ip; font-size: 17px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; }
                                }
                            }

                            // Gateway Card
                            Rectangle {
                                width: 100%;
                                height: 60px;
                                border-radius: 8px;
                                background: rgba(255, 255, 255, 0.03);
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.06);
                                clip: true;

                                // Left accent line (Purple)
                                Rectangle {
                                    x: 0;
                                    y: 0;
                                    width: 4px;
                                    height: 100%;
                                    background: #8b5cf6;
                                }

                                VerticalLayout {
                                    padding-left: 16px;
                                    padding-right: 12px;
                                    padding-top: 6px;
                                    padding-bottom: 6px;
                                    spacing: 1px;
                                    alignment: center;
                                    Text { text: "GATEWAY"; font-size: 12px; font-weight: 800; color: #888888; font-family: "Rajdhani"; }
                                    Text { text: root.network_gateway; font-size: 17px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; }
                                }
                            }
                        }

                        // --- Wi-Fi Networks Panel ---
                        if (root.network_sub_tab == 1) : VerticalLayout {
                            spacing: 10px;
                            alignment: start;

                            // Scan Button
                            TouchArea {
                                height: 40px;
                                enabled: !root.wifi_scanning;
                                clicked => { root.wifi_scan(); }
                                Rectangle {
                                    width: 100%;
                                    height: 100%;
                                    border-radius: 6px;
                                    background: root.wifi_scanning ? rgba(255, 255, 255, 0.02) : rgba(255, 255, 255, 0.05);
                                    border-width: 1px;
                                    border-color: root.wifi_scanning ? rgba(255, 255, 255, 0.05) : rgba(255, 255, 255, 0.1);

                                    animate background { duration: 150ms; }
                                    animate border-color { duration: 150ms; }

                                    Text {
                                        text: root.wifi_scanning ? "SCANNING FOR NETWORKS... ↻" : "SCAN FOR NETWORKS";
                                        font-size: 14px;
                                        font-weight: 800;
                                        color: root.wifi_scanning ? #888888 : #ffffff;
                                        font-family: "Rajdhani";
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Discovered list box
                            Rectangle {
                                width: 100%;
                                height: 220px;
                                background: rgba(0, 0, 0, 0.3);
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.06);
                                clip: true;

                                if (root.wifi_networks.length == 0 && !root.wifi_scanning) : VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: "No networks scanned yet. Tap Scan to search.";
                                        font-size: 14px;
                                        font-weight: 700;
                                        color: #666666;
                                        font-family: "Rajdhani";
                                        horizontal-alignment: center;
                                    }
                                }

                                if (root.wifi_networks.length > 0) : wifi_scroll_view := ScrollView {
                                    width: 100%;
                                    height: 100%;
                                    VerticalLayout {
                                        padding: 4px;
                                        spacing: 4px;

                                        for net[idx] in root.wifi_networks : TouchArea {
                                            height: 40px;
                                            clicked => {
                                                let dy = (self.mouse-y - self.pressed-y) / 1px;
                                                let dx = (self.mouse-x - self.pressed-x) / 1px;
                                                if (dy * dy + dx * dx < 100) {
                                                    root.wifi_selected_ssid = net.ssid;
                                                    root.wifi_typed_password = "";
                                                    root.wifi_keyboard_open = true;
                                                    root.wifi_connection_error = "";
                                                }
                                            }
                                            moved => {
                                                if (self.pressed) {
                                                    let min_y = wifi_scroll_view.height - wifi_scroll_view.viewport-height;
                                                    let max_y = 0px;
                                                    if (min_y > 0px) {
                                                        wifi_scroll_view.viewport-y = 0px;
                                                    } else {
                                                        wifi_scroll_view.viewport-y = max(min_y, min(max_y, wifi_scroll_view.viewport-y + self.mouse-y - self.pressed-y));
                                                    }
                                                }
                                            }
                                            Rectangle {
                                                width: 100%;
                                                height: 100%;
                                                border-radius: 4px;
                                                background: (net.ssid == root.network_ssid && root.network_ssid != "--" && root.network_ssid != "") ? rgba(16, 185, 129, 0.12) : rgba(255, 255, 255, 0.02);
                                                border-width: 1px;
                                                border-color: (net.ssid == root.network_ssid && root.network_ssid != "--" && root.network_ssid != "") ? rgba(16, 185, 129, 0.4) : transparent;

                                                animate background { duration: 150ms; }
                                                animate border-color { duration: 150ms; }

                                                HorizontalLayout {
                                                    padding-left: 12px;
                                                    padding-right: 12px;
                                                    alignment: space-between;

                                                    Text {
                                                        text: (net.ssid == root.network_ssid && root.network_ssid != "--" && root.network_ssid != "") ? net.ssid + " ✓" : net.ssid;
                                                        font-size: 15px;
                                                        font-weight: 700;
                                                        color: (net.ssid == root.network_ssid && root.network_ssid != "--" && root.network_ssid != "") ? #10b981 : #ffffff;
                                                        font-family: "Rajdhani";
                                                        vertical-alignment: center;
                                                    }

                                                    HorizontalLayout {
                                                        spacing: 12px;
                                                        alignment: end;

                                                        // Connected badge
                                                        if (net.ssid == root.network_ssid && root.network_ssid != "--" && root.network_ssid != "") : Rectangle {
                                                            width: 72px;
                                                            height: 18px;
                                                            y: (parent.height - 18px) / 2;
                                                            border-radius: 3px;
                                                            background: rgba(16, 185, 129, 0.15);
                                                            border-width: 1px;
                                                            border-color: rgba(16, 185, 129, 0.3);
                                                            Text {
                                                                text: "CONNECTED";
                                                                font-size: 10px;
                                                                font-weight: 800;
                                                                color: #10b981;
                                                                font-family: "Rajdhani";
                                                                horizontal-alignment: center;
                                                                vertical-alignment: center;
                                                            }
                                                        }

                                                        // Secure lock icon
                                                        if (net.secured) : Rectangle {
                                                            width: 12px;
                                                            height: 14px;
                                                            y: (parent.height - 14px) / 2;
                                                            // Shackle
                                                            Rectangle {
                                                                x: 2px;
                                                                y: 0px;
                                                                width: 8px;
                                                                height: 7px;
                                                                border-radius: 3px;
                                                                border-width: 1.5px;
                                                                border-color: #888888;
                                                            }
                                                            // Body
                                                            Rectangle {
                                                                x: 1px;
                                                                y: 6px;
                                                                width: 100%;
                                                                height: 8px;
                                                                border-radius: 1px;
                                                                background: #888888;
                                                            }
                                                        }

                                                        // Signal bars
                                                        Rectangle {
                                                            width: 16px;
                                                            height: 12px;
                                                            y: (parent.height - 12px) / 2;
                                                            Rectangle { x: 0px; y: 9px; width: 2.5px; height: 3px; background: #ffffff; border-radius: 0.5px; }
                                                            Rectangle { x: 4px; y: 6px; width: 2.5px; height: 6px; background: net.signal >= 35 ? #ffffff : rgba(255,255,255,0.15); border-radius: 0.5px; }
                                                            Rectangle { x: 8px; y: 3px; width: 2.5px; height: 9px; background: net.signal >= 60 ? #ffffff : rgba(255,255,255,0.15); border-radius: 0.5px; }
                                                            Rectangle { x: 12px; y: 0px; width: 2.5px; height: 12px; background: net.signal >= 80 ? #ffffff : rgba(255,255,255,0.15); border-radius: 0.5px; }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                        }
                    }
                }

                    // --- System Tab ---
                    if (root.system_tab_index == 4) : VerticalLayout {
                        padding: 16px;
                        spacing: 12px;
                        alignment: start;

                        Text {
                            text: "SYSTEM";
                            font-size: 22px;
                            font-weight: 800;
                            color: #ffffff;
                            font-family: "Rajdhani";
                        }

                        // Section 1: Metrics
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "SYSTEM METRICS"; font-size: 11px; font-weight: 800; color: #888888; font-family: "Rajdhani"; }
                            HorizontalLayout {
                                spacing: 12px;

                                Rectangle {
                                    width: parent.width / 2 - 6px;
                                    height: 72px;
                                    border-radius: 8px;
                                    background: rgba(255, 255, 255, 0.03);
                                    border-width: 1px;
                                    border-color: rgba(255, 255, 255, 0.06);

                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 4px;
                                        Text { text: "CPU TEMP"; font-size: 13px; font-weight: 700; color: #b5bcc8; font-family: "Rajdhani"; }
                                        Text { text: root.cpu_temp; font-size: 22px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; }
                                    }
                                }

                                Rectangle {
                                    width: parent.width / 2 - 6px;
                                    height: 72px;
                                    border-radius: 8px;
                                    background: rgba(255, 255, 255, 0.03);
                                    border-width: 1px;
                                    border-color: rgba(255, 255, 255, 0.06);

                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 4px;
                                        Text { text: "UPTIME"; font-size: 13px; font-weight: 700; color: #b5bcc8; font-family: "Rajdhani"; }
                                        Text { text: root.system_uptime; font-size: 18px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; overflow: elide; }
                                    }
                                }
                            }
                        }

                        // Section 2: Firmware & Hardware
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "FIRMWARE & HARDWARE"; font-size: 11px; font-weight: 800; color: #888888; font-family: "Rajdhani"; }
                            Rectangle {
                                width: 100%;
                                height: 56px;
                                border-radius: 8px;
                                background: rgba(255, 255, 255, 0.03);
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.06);
                                clip: true;

                                // Left accent line (Silver/Gray)
                                Rectangle {
                                    x: 0;
                                    y: 0;
                                    width: 4px;
                                    height: 100%;
                                    background: #b5bcc8;
                                }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: space-between;

                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "DEVICE MODEL"; font-size: 11px; font-weight: 800; color: #888888; font-family: "Rajdhani"; }
                                        Text { text: root.system_model; font-size: 15px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 2px;
                                        Text { text: "SOFTWARE VERSION"; font-size: 11px; font-weight: 800; color: #888888; font-family: "Rajdhani"; horizontal-alignment: right; }
                                        Text { text: root.system_version; font-size: 15px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: right; }
                                    }
                                }
                            }
                        }

                        // Section 3: Power Actions
                        VerticalLayout {
                            spacing: 4px;
                            Text { text: "POWER CONTROL"; font-size: 11px; font-weight: 800; color: #888888; font-family: "Rajdhani"; }
                            HorizontalLayout {
                                spacing: 12px;

                                reboot_btn := TouchArea {
                                    width: parent.width / 2 - 6px;
                                    height: 52px;
                                    enabled: !root.is_recording;
                                    clicked => { root.system_confirm_action = "reboot"; root.system_confirm_open = true; }
                                    Rectangle {
                                        width: 100%;
                                        height: 100%;
                                        border-radius: 8px;
                                        background: reboot_btn.pressed ? rgba(255, 204, 0, 0.20) : reboot_btn.has-hover ? rgba(255, 204, 0, 0.14) : rgba(255, 204, 0, 0.08);
                                        border-width: 1px;
                                        border-color: reboot_btn.pressed ? #ffcc00 : reboot_btn.has-hover ? rgba(255, 204, 0, 0.6) : rgba(255, 204, 0, 0.35);

                                        animate background { duration: 100ms; }
                                        animate border-color { duration: 100ms; }

                                        Text {
                                            text: "REBOOT ↻";
                                            font-size: 15px;
                                            font-weight: 800;
                                            color: #ffcc00;
                                            font-family: "Rajdhani";
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                shutdown_btn := TouchArea {
                                    width: parent.width / 2 - 6px;
                                    height: 52px;
                                    enabled: !root.is_recording;
                                    clicked => { root.system_confirm_action = "shutdown"; root.system_confirm_open = true; }
                                    Rectangle {
                                        width: 100%;
                                        height: 100%;
                                        border-radius: 8px;
                                        background: shutdown_btn.pressed ? rgba(255, 59, 48, 0.22) : shutdown_btn.has-hover ? rgba(255, 59, 48, 0.16) : rgba(255, 59, 48, 0.10);
                                        border-width: 1px;
                                        border-color: shutdown_btn.pressed ? #ff3b30 : shutdown_btn.has-hover ? rgba(255, 59, 48, 0.6) : rgba(255, 59, 48, 0.35);

                                        animate background { duration: 100ms; }
                                        animate border-color { duration: 100ms; }

                                        Text {
                                            text: "SHUTDOWN ⏻";
                                            font-size: 15px;
                                            font-weight: 800;
                                            color: #ff5c5c;
                                            font-family: "Rajdhani";
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // Confirm Modal for Destructive Actions
        if (root.system_confirm_open) : Rectangle {
            x: 0;
            y: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);

            TouchArea {
                clicked => { root.system_confirm_open = false; root.system_confirm_action = ""; }
            }

            Rectangle {
                width: 400px;
                height: 220px;
                x: parent.width / 2 - self.width / 2;
                y: parent.height / 2 - self.height / 2;
                background: rgba(20, 10, 10, 0.95);
                border-radius: 12px;
                border-width: 2px;
                border-color: #ff5c5c;

                VerticalLayout {
                    padding: 24px;
                    alignment: space-between;
                    spacing: 16px;

                    VerticalLayout {
                        spacing: 10px;
                        alignment: center;
                        Text {
                            text: root.system_confirm_action == "shutdown" ? "SHUTDOWN?" : root.system_confirm_action == "reboot" ? "REBOOT?" : "DELETE ALL RECORDINGS?";
                            font-size: 24px;
                            font-weight: 800;
                            color: #ff5c5c;
                            font-family: "Rajdhani";
                            horizontal-alignment: center;
                        }
                        Text {
                            text: root.system_confirm_action == "shutdown" ? "The device will power off." : root.system_confirm_action == "reboot" ? "The device will restart." : "All recordings will be permanently deleted.";
                            font-size: 16px;
                            color: #888888;
                            font-family: "Rajdhani";
                            horizontal-alignment: center;
                        }
                    }

                    HorizontalLayout {
                        spacing: 20px;
                        alignment: center;

                        TouchArea {
                            width: 140px;
                            height: 52px;
                            clicked => { root.system_confirm_open = false; root.system_confirm_action = ""; }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                border-radius: 8px;
                                background: rgba(255, 255, 255, 0.08);
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.15);
                                Text {
                                    text: "CANCEL";
                                    font-size: 18px;
                                    font-weight: 800;
                                    color: #ffffff;
                                    font-family: "Rajdhani";
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        TouchArea {
                            width: 140px;
                            height: 52px;
                            clicked => {
                                root.system_confirm_open = false;
                                if (root.system_confirm_action == "shutdown") {
                                    root.system_shutdown();
                                } else if (root.system_confirm_action == "reboot") {
                                    root.system_reboot();
                                } else if (root.system_confirm_action == "delete_all") {
                                    root.delete_all_recordings();
                                }
                                root.system_confirm_action = "";
                            }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                border-radius: 8px;
                                background: #ff5c5c;
                                Text {
                                    text: "CONFIRM";
                                    font-size: 18px;
                                    font-weight: 900;
                                    color: #ffffff;
                                    font-family: "Rajdhani";
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
            }
        }
    }
}

        if (root.wifi_keyboard_open) : Rectangle {
            x: 0;
            y: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);

            TouchArea {
                clicked => {
                    root.wifi_keyboard_open = false;
                }
            }

            Rectangle {
                width: 620px;
                height: 430px;
                x: parent.width / 2 - self.width / 2;
                y: parent.height / 2 - self.height / 2;
                background: #14161f;
                border-radius: 12px;
                border-width: 2px;
                border-color: #2a2e3d;

                TouchArea {}

                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;
                    alignment: space-between;

                    HorizontalLayout {
                        alignment: space-between;
                        height: 40px;

                        Text {
                            text: "CONNECT TO: " + root.wifi_selected_ssid;
                            font-size: 18px;
                            font-weight: 800;
                            color: #00d2ff;
                            font-family: "Rajdhani";
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 40px;
                            height: 40px;
                            clicked => {
                                root.wifi_keyboard_open = false;
                                root.wifi_connection_error = "";
                            }
                            Rectangle {
                                background: parent.pressed ? rgba(255, 80, 80, 0.3) : rgba(255, 255, 255, 0.05);
                                border-radius: 20px;
                                Text {
                                    text: "✕";
                                    font-size: 20px;
                                    color: #ff5c5c;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        height: 48px;

                        Rectangle {
                            horizontal-stretch: 1;
                            background: rgba(0, 0, 0, 0.4);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.1);
                            clip: true;

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                alignment: start;

                                Text {
                                    text: root.wifi_typed_password == "" ? "Enter Password..." : root.wifi_typed_password;
                                    font-size: 18px;
                                    font-family: "Rajdhani";
                                    font-weight: 700;
                                    color: root.wifi_typed_password == "" ? rgba(255, 255, 255, 0.3) : #ffffff;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        TouchArea {
                            width: 70px;
                            clicked => {
                                root.wifi_backspace();
                            }
                            Rectangle {
                                background: parent.pressed ? rgba(255, 255, 255, 0.2) : rgba(255, 255, 255, 0.08);
                                border-radius: 6px;
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.15);
                                Text {
                                    text: "⌫";
                                    font-size: 20px;
                                    color: #ffffff;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        alignment: center;

                        HorizontalLayout {
                            spacing: 6px;
                            alignment: center;
                            if (!root.wifi_keyboard_symbols) : HorizontalLayout {
                                spacing: 6px;
                                for char in (root.wifi_keyboard_shift ? ["Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P"] : ["q", "w", "e", "r", "t", "y", "u", "i", "o", "p"]) : TouchArea {
                                    width: 50px;
                                    height: 44px;
                                    clicked => { root.wifi_type_key(char); }
                                    Rectangle {
                                        background: parent.pressed ? rgba(255, 255, 255, 0.2) : rgba(255, 255, 255, 0.08);
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: rgba(255, 255, 255, 0.15);
                                        Text { text: char; font-size: 20px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }
                            if (root.wifi_keyboard_symbols) : HorizontalLayout {
                                spacing: 6px;
                                for char in ["1", "2", "3", "4", "5", "6", "7", "8", "9", "0"] : TouchArea {
                                    width: 50px;
                                    height: 44px;
                                    clicked => { root.wifi_type_key(char); }
                                    Rectangle {
                                        background: parent.pressed ? rgba(255, 255, 255, 0.2) : rgba(255, 255, 255, 0.08);
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: rgba(255, 255, 255, 0.15);
                                        Text { text: char; font-size: 20px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 6px;
                            alignment: center;
                            if (!root.wifi_keyboard_symbols) : HorizontalLayout {
                                spacing: 6px;
                                for char in (root.wifi_keyboard_shift ? ["A", "S", "D", "F", "G", "H", "J", "K", "L"] : ["a", "s", "d", "f", "g", "h", "j", "k", "l"]) : TouchArea {
                                    width: 50px;
                                    height: 44px;
                                    clicked => { root.wifi_type_key(char); }
                                    Rectangle {
                                        background: parent.pressed ? rgba(255, 255, 255, 0.2) : rgba(255, 255, 255, 0.08);
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: rgba(255, 255, 255, 0.15);
                                        Text { text: char; font-size: 20px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }
                            if (root.wifi_keyboard_symbols) : HorizontalLayout {
                                spacing: 6px;
                                for char in ["-", "/", ":", ";", "(", ")", "$", "&", "@", "\""] : TouchArea {
                                    width: 50px;
                                    height: 44px;
                                    clicked => { root.wifi_type_key(char); }
                                    Rectangle {
                                        background: parent.pressed ? rgba(255, 255, 255, 0.2) : rgba(255, 255, 255, 0.08);
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: rgba(255, 255, 255, 0.15);
                                        Text { text: char; font-size: 20px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 6px;
                            alignment: center;
                            if (!root.wifi_keyboard_symbols) : HorizontalLayout {
                                spacing: 6px;

                                TouchArea {
                                    width: 64px;
                                    height: 44px;
                                    clicked => { root.wifi_keyboard_shift = !root.wifi_keyboard_shift; }
                                    Rectangle {
                                        background: root.wifi_keyboard_shift ? rgba(0, 210, 255, 0.25) : rgba(255, 255, 255, 0.08);
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: root.wifi_keyboard_shift ? #00d2ff : rgba(255, 255, 255, 0.15);
                                        Text { text: "⇧"; font-size: 22px; color: root.wifi_keyboard_shift ? #00d2ff : #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }

                                for char in (root.wifi_keyboard_shift ? ["Z", "X", "C", "V", "B", "N", "M"] : ["z", "x", "c", "v", "b", "n", "m"]) : TouchArea {
                                    width: 50px;
                                    height: 44px;
                                    clicked => { root.wifi_type_key(char); }
                                    Rectangle {
                                        background: parent.pressed ? rgba(255, 255, 255, 0.2) : rgba(255, 255, 255, 0.08);
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: rgba(255, 255, 255, 0.15);
                                        Text { text: char; font-size: 20px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }

                                Rectangle { width: 64px; height: 44px; background: transparent; }
                            }
                            if (root.wifi_keyboard_symbols) : HorizontalLayout {
                                spacing: 6px;
                                for char in [".", ",", "?", "!", "'", "_", "+", "=", "*", "#", "%", "\\"] : TouchArea {
                                    width: 44px;
                                    height: 44px;
                                    clicked => { root.wifi_type_key(char); }
                                    Rectangle {
                                        background: parent.pressed ? rgba(255, 255, 255, 0.2) : rgba(255, 255, 255, 0.08);
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: rgba(255, 255, 255, 0.15);
                                        Text { text: char; font-size: 20px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            alignment: center;

                            TouchArea {
                                width: 110px;
                                height: 44px;
                                clicked => { root.wifi_keyboard_symbols = !root.wifi_keyboard_symbols; }
                                Rectangle {
                                    background: rgba(255, 255, 255, 0.1);
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: rgba(255, 255, 255, 0.15);
                                    Text {
                                        text: root.wifi_keyboard_symbols ? "ABC" : "?123";
                                        font-size: 16px;
                                        font-weight: 800;
                                        color: #ffffff;
                                        font-family: "Rajdhani";
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            TouchArea {
                                width: 260px;
                                height: 44px;
                                clicked => { root.wifi_type_key(" "); }
                                Rectangle {
                                    background: parent.pressed ? rgba(255, 255, 255, 0.2) : rgba(255, 255, 255, 0.08);
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: rgba(255, 255, 255, 0.15);
                                    Text {
                                        text: "SPACE";
                                        font-size: 16px;
                                        font-weight: 800;
                                        color: rgba(255, 255, 255, 0.5);
                                        font-family: "Rajdhani";
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            TouchArea {
                                width: 150px;
                                height: 44px;
                                clicked => {
                                    root.wifi_connecting = true;
                                    root.wifi_connection_error = "";
                                    root.wifi_connect(root.wifi_selected_ssid, root.wifi_typed_password);
                                }
                                Rectangle {
                                    background: parent.pressed ? #00b3d6 : #00d2ff;
                                    border-radius: 6px;
                                    Text {
                                        text: "CONNECT";
                                        font-size: 16px;
                                        font-weight: 900;
                                        color: #0a0c10;
                                        font-family: "Rajdhani";
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    if (root.wifi_connection_error != "" || root.wifi_connecting) : Rectangle {
                        height: 52px;
                        background: root.wifi_connecting ? rgba(0, 210, 255, 0.15) : rgba(255, 92, 92, 0.15);
                        border-radius: 6px;
                        border-width: 1.5px;
                        border-color: root.wifi_connecting ? #00d2ff : #ff5c5c;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            alignment: center;
                            Text {
                                text: root.wifi_connecting ? "CONNECTING TO " + root.wifi_selected_ssid + "... ↻" : "ERROR: " + root.wifi_connection_error;
                                font-size: 15px;
                                font-weight: 800;
                                color: root.wifi_connecting ? #00d2ff : #ff5c5c;
                                font-family: "Rajdhani";
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }
    }


    Rectangle {
        visible: root.compact_mode && !root.media_open && !root.system_open;
        x: 0;
        y: 0;
        width: root.width;
        height: 56px;
        background: rgba(0, 0, 0, 0.6);

        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 4px;
            padding-bottom: 4px;
            alignment: space-between;

            if (!root.full_auto) : VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    spacing: 32px;

                    VerticalLayout {
                        spacing: 4px;
                        VerticalLayout {
                            spacing: 1px;
                            Text { text: "FPS"; font-size: 14px; font-weight: 700; color: #b5bcc8; font-family: "Rajdhani"; }
                            Text { text: root.current_fps; font-size: 24px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; }
                        }
                    }
                    VerticalLayout {
                        spacing: 4px;
                        VerticalLayout {
                            spacing: 1px;
                            Text { text: "ISO"; font-size: 14px; font-weight: 700; color: #b5bcc8; font-family: "Rajdhani"; }
                            Text { text: root.current_iso; font-size: 24px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; }
                        }
                    }
                    VerticalLayout {
                        spacing: 4px;
                        VerticalLayout {
                            spacing: 1px;
                            Text { text: "SHUTT"; font-size: 14px; font-weight: 700; color: #b5bcc8; font-family: "Rajdhani"; }
                            Text { text: root.current_shutter; font-size: 24px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; }
                        }
                    }
                    VerticalLayout {
                        spacing: 4px;
                        VerticalLayout {
                            spacing: 1px;
                            Text { text: "WB"; font-size: 14px; font-weight: 700; color: #b5bcc8; font-family: "Rajdhani"; }
                            Text { text: root.current_wb; font-size: 24px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; }
                        }
                    }
                }
            }

            if (root.full_auto) : VerticalLayout {
                alignment: center;
                VerticalLayout {
                    spacing: 1px;
                    Text { text: "MODE"; font-size: 14px; font-weight: 700; color: #b5bcc8; font-family: "Rajdhani"; }
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: #10b981;
                            }
                        }
                        Text { text: "AUTO"; font-size: 24px; font-weight: 800; color: #10b981; font-family: "Rajdhani"; }
                    }
                }
            }

            HorizontalLayout {
                alignment: center;
                spacing: 6px;

                // Media Browser
                TouchArea {
                    width: 48px;
                    height: 48px;
                    enabled: !root.is_recording && !root.record_busy;
                    clicked => { root.toggle_media(); }
                    Image {
                        width: 32px;
                        height: 32px;
                        x: parent.width / 2 - self.width / 2;
                        y: parent.height / 2 - self.height / 2;
                        source: @image-url("assets/img/monitor.png");
                        image-fit: contain;
                    }
                }

                // System Settings
                TouchArea {
                    width: 48px;
                    height: 48px;
                    enabled: !root.is_recording && !root.record_busy;
                    clicked => { root.toggle_system(); }
                    Rectangle {
                        width: 100%;
                        height: 100%;
                        border-radius: 24px;
                        background: rgba(255, 255, 255, 0.08);
                        Text {
                            text: "SYS";
                            font-size: 11px;
                            font-weight: 800;
                            color: #ffffff;
                            font-family: "Rajdhani";
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    Rectangle {
        visible: !root.compact_mode;
        x: 0;
        y: 0;
        width: root.viewfinder_width;
        height: 75px;
        background: @linear-gradient(180deg, rgba(0, 0, 0, 0.6) 0, rgba(0, 0, 0, 0) 1);

        HorizontalLayout {
            padding-left: 20px;
            padding-right: 20px;
            padding-top: 12px;
            alignment: space-between;

            HorizontalLayout {
                spacing: 24px;
                VerticalLayout { Text { text: "FPS"; font-size: 11px; color: #aaaaaa; font-weight: 700; } Text { text: root.current_fps; font-size: 18px; color: #ffffff; } }
                VerticalLayout { Text { text: "SHUTTER"; font-size: 11px; color: #aaaaaa; font-weight: 700; } Text { text: root.current_shutter; font-size: 18px; color: #ffffff; } }
            }

            Text {
                text: root.timecode;
                font-size: 32px;
                font-weight: 500;
                color: #ffffff;
                font-family: "monospace";
                vertical-alignment: center;
            }

            HorizontalLayout {
                spacing: 24px;
                VerticalLayout { Text { text: "ISO"; font-size: 11px; color: #aaaaaa; font-weight: 700; } Text { text: root.current_iso; font-size: 18px; color: #ffffff; } }
                VerticalLayout { Text { text: "WB"; font-size: 11px; color: #aaaaaa; font-weight: 700; } Text { text: root.current_wb; font-size: 18px; color: #ffffff; } }
                VerticalLayout { Text { text: "TINT"; font-size: 11px; color: #aaaaaa; font-weight: 700; } Text { text: root.current_tint; font-size: 18px; color: #ffffff; } }
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        background: #333333;
                        border-radius: 3px;
                        width: 56px;
                        height: 22px;
                        Text { text: root.current_resolution; font-size: 11px; font-weight: 900; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Text { text: root.current_aspect_ratio; font-size: 9px; color: #aaaaaa; horizontal-alignment: center; }
                }
            }
        }
    }

    Rectangle {
        visible: root.compact_mode && root.exposure_overlay_visible && !root.media_open && !root.system_open;
        x: root.settings_open ? 142px : 10px;
        y: root.height - self.height - 84px;
        width: 66px;
        height: 144px;
        background: rgba(0, 0, 0, 0.34);
        border-radius: 10px;
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.12);
        animate x { duration: 160ms; }

        VerticalLayout {
            padding-top: 8px;
            padding-bottom: 8px;
            alignment: space-between;

            Rectangle {
                width: 30px;
                height: 30px;
                x: parent.width / 2 - self.width / 2;
                border-radius: 15px;
                background: root.exposure_signal == 2 ? #ff3b30 : root.exposure_signal == 1 ? #ffcc00 : rgba(255, 255, 255, 0.18);
            }

            Rectangle {
                width: 30px;
                height: 30px;
                x: parent.width / 2 - self.width / 2;
                border-radius: 15px;
                background: root.exposure_signal == 0 ? #34c759 : rgba(255, 255, 255, 0.18);
            }

            Rectangle {
                width: 30px;
                height: 30px;
                x: parent.width / 2 - self.width / 2;
                border-radius: 15px;
                background: root.exposure_signal == -2 ? #ff3b30 : root.exposure_signal == -1 ? #ffcc00 : rgba(255, 255, 255, 0.18);
            }

            Text {
                text: root.exposure_signal > 0 ? "HIGH" : root.exposure_signal < 0 ? "LOW" : "OK";
                font-size: 12px;
                font-weight: 800;
                color: #f5f8ff;
                font-family: "Rajdhani";
                horizontal-alignment: center;
                width: parent.width;
            }
        }
    }

    Rectangle {
        visible: root.compact_mode && !root.media_open && !root.system_open;
        x: root.exposure_overlay_visible
            ? (root.settings_open ? 216px : 84px)
            : (root.settings_open ? 142px : 10px);
        y: root.height - self.height - 84px;
        width: 56px;
        height: 144px;
        background: rgba(0, 0, 0, 0.34);
        border-radius: 10px;
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.12);
        animate x { duration: 160ms; }

        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            padding-top: 8px;
            padding-bottom: 18px;
            spacing: 8px;
            alignment: center;

            Rectangle {
                width: 12px;
                height: 118px;
                border-radius: 6px;
                background: rgba(255, 255, 255, 0.12);

                Rectangle {
                    x: 0;
                    y: parent.height - self.height;
                    width: parent.width;
                    height: parent.height * root.audio_level_left;
                    background: root.audio_clip_left ? #ff3b30 : root.audio_level_left >= 0.82 ? #ffcc00 : #4cd964;
                    border-radius: 6px;
                }

                Rectangle {
                    x: 0;
                    y: parent.height * (1.0 - root.audio_peak_left) - 1px;
                    width: parent.width;
                    height: 2px;
                    background: #ffffff;
                    visible: root.audio_peak_left > 0;
                }
            }

            Rectangle {
                width: 12px;
                height: 118px;
                border-radius: 6px;
                background: rgba(255, 255, 255, 0.12);

                Rectangle {
                    x: 0;
                    y: parent.height - self.height;
                    width: parent.width;
                    height: parent.height * root.audio_level_right;
                    background: root.audio_clip_right ? #ff3b30 : root.audio_level_right >= 0.82 ? #ffcc00 : #4cd964;
                    border-radius: 6px;
                }

                Rectangle {
                    x: 0;
                    y: parent.height * (1.0 - root.audio_peak_right) - 1px;
                    width: parent.width;
                    height: 2px;
                    background: #ffffff;
                    visible: root.audio_peak_right > 0;
                }
            }

        }
    }

    Rectangle {
        visible: !root.compact_mode;
        x: root.overlay_margin;
        y: root.height - self.height - 20px;
        width: 180px;
        height: 110px;
        background: rgba(0, 0, 0, 0.5);
        border-radius: 4px;
        border-width: 1px;
        border-color: #333333;
        Text { text: "Rec.709 Histogram"; font-size: 11px; color: #888888; x: 8px; y: 6px; }
        Rectangle { x: 10px; y: 25px; width: 160px; height: 75px; background: rgba(50, 150, 50, 0.2); border-width: 1px; border-color: #444444; }
    }

    Rectangle {
        visible: !root.compact_mode;
        x: root.viewfinder_width / 2 - self.width / 2;
        y: root.height - self.height - 20px;
        width: 220px;
        height: 90px;
        background: rgba(0, 0, 0, 0.6);
        border-radius: 6px;
        border-width: 1px;
        border-color: #333333;
        HorizontalLayout {
            padding: 15px;
            spacing: 15px;
            Rectangle {
                width: 30px;
                height: 50px;
                border-width: 2px;
                border-color: root.is_recording ? #ff3b30 : #ffffff;
                border-radius: 4px;
                background: root.is_recording ? rgba(255, 59, 48, 0.18) : transparent;
            }
            VerticalLayout {
                spacing: 3px;
                Text { text: root.current_media_status; font-size: 11px; color: root.is_recording ? #ff3b30 : #aaaaaa; font-weight: 800; }
                Text { text: root.timecode; font-size: 20px; color: #ffffff; font-weight: 700; font-family: "monospace"; }
                Text { text: root.current_media_detail; font-size: 12px; color: #aaaaaa; overflow: elide; }
            }
        }
    }

    Rectangle {
        visible: !root.compact_mode;
        x: root.viewfinder_width - self.width - root.overlay_margin;
        y: root.height - self.height - 20px;
        width: 220px;
        height: 90px;
        background: rgba(0, 0, 0, 0.6);
        border-radius: 6px;
        border-width: 1px;
        border-color: #333333;
        Text { text: "Default Audio"; font-size: 10px; color: #aaaaaa; x: 12px; y: 8px; }
        VerticalLayout {
            x: 12px;
            y: 30px;
            spacing: 6px;
            width: 196px;
            Rectangle {
                height: 8px;
                background: #222222;
                border-radius: 4px;

                Rectangle {
                    x: 0;
                    width: parent.width * root.audio_level_left;
                    height: 100%;
                    background: root.audio_clip_left ? #ff3b30 : root.audio_level_left >= 0.82 ? #ffcc00 : #4cd964;
                    border-radius: 4px;
                }

                Rectangle {
                    x: parent.width * root.audio_peak_left - 1px;
                    width: 2px;
                    height: 100%;
                    background: #ffffff;
                    visible: root.audio_peak_left > 0;
                }
            }
            Rectangle {
                height: 8px;
                background: #222222;
                border-radius: 4px;

                Rectangle {
                    x: 0;
                    width: parent.width * root.audio_level_right;
                    height: 100%;
                    background: root.audio_clip_right ? #ff3b30 : root.audio_level_right >= 0.82 ? #ffcc00 : #4cd964;
                    border-radius: 4px;
                }

                Rectangle {
                    x: parent.width * root.audio_peak_right - 1px;
                    width: 2px;
                    height: 100%;
                    background: #ffffff;
                    visible: root.audio_peak_right > 0;
                }
            }
            Text { text: "-45  -30  -20  -10  -6  -3  0  3"; font-size: 9px; color: #666666; }
        }
    }

    Rectangle {
        visible: !root.compact_mode;
        x: root.width - root.control_strip_width;
        y: 0;
        width: root.control_strip_width;
        height: root.height;
        background: #090a0c;
        border-width: 1px;
        border-color: #1a1c1f;

        VerticalLayout {
            padding-top: 30px;
            padding-bottom: 30px;
            alignment: space-between;

            VerticalLayout {
                spacing: 25px;
                HorizontalLayout { alignment: center; Rectangle { width: 40px; height: 40px; border-width: 1px; border-color: #444444; border-radius: 5px; Text { text: "CAM"; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; } } }
                HorizontalLayout { alignment: center; Rectangle { width: 40px; height: 40px; border-width: 1px; border-color: #444444; border-radius: 5px; Image { width: 22px; height: 22px; x: parent.width / 2 - self.width / 2; y: parent.height / 2 - self.height / 2; source: @image-url("assets/img/zoom.png"); image-fit: contain; } } }
            }

            TouchArea {
                enabled: !root.record_busy;
                clicked => { root.toggle_record(); }
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 76px;
                        height: 76px;
                        border-radius: 38px;
                        border-width: 4px;
                        border-color: #ffffff;
                        background: transparent;

                        Rectangle {
                            x: parent.width / 2 - (root.is_recording ? 20px : 26px);
                            y: parent.height / 2 - (root.is_recording ? 20px : 26px);
                            width: root.is_recording ? 40px : 52px;
                            height: root.is_recording ? 40px : 52px;
                            border-radius: root.is_recording ? 6px : 26px;
                            background: #ff3b30;
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 25px;
                HorizontalLayout { alignment: center; Rectangle { width: 45px; height: 30px; background: #222222; border-radius: 4px; Text { text: "LUT"; font-size: 12px; font-weight: 800; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; } } }
                HorizontalLayout { alignment: center; Rectangle { width: 40px; height: 40px; border-width: 1px; border-color: #444444; border-radius: 5px; Text { text: "MENU"; font-size: 10px; color: #aaaaaa; horizontal-alignment: center; vertical-alignment: center; } } }
            }
        }
    }

    Rectangle {
        visible: root.compact_mode && !root.media_open && !root.system_open;
        x: 0;
        y: root.height - self.height;
        width: root.width;
        height: 72px;
        background: rgba(0, 0, 0, 0.6);

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 4px;
            padding-bottom: 4px;
            alignment: space-between;

            // Left block: Status (Dot and label, and media detail)
            VerticalLayout {
                alignment: center;
                width: 180px;

                VerticalLayout {
                    spacing: 5px;
                    alignment: center;

                    HorizontalLayout {
                        alignment: start;
                        spacing: 6px;

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 10px;
                                height: 10px;
                                border-radius: 5px;
                                background: root.is_recording ? #ff3b30 : (root.record_busy ? #ff9500 : #4cd964);
                            }
                        }

                        Text {
                            text: root.current_media_status;
                            font-size: 12px;
                            font-weight: 800;
                            color: #b5bcc8;
                            font-family: "Rajdhani";
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: root.current_media_detail;
                        font-size: 22px;
                        font-weight: 700;
                        color: #ffffff;
                        font-family: "Rajdhani";
                        overflow: elide;
                    }
                }
            }

            // Center block: REC Button + Timecode
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    spacing: 16px;
                    alignment: center;

                    TouchArea {
                        width: 76px;
                        height: 46px;
                        enabled: !root.record_busy;
                        clicked => { root.toggle_record(); }

                        Rectangle {
                            width: parent.width;
                            height: parent.height;
                            border-radius: 4px;
                            border-width: 2px;
                            border-color: #ff3b30;
                            background: root.is_recording ? rgba(255, 59, 48, 0.3) : rgba(0, 0, 0, 0.4);

                            Text {
                                text: "REC";
                                font-size: 22px;
                                font-weight: 900;
                                color: #ff3b30;
                                font-family: "Rajdhani";
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Text {
                        text: root.timecode;
                        font-size: 38px;
                        font-weight: 700;
                        color: root.is_recording ? #ff3b30 : #ffffff;
                        font-family: "Rajdhani";
                        vertical-alignment: center;
                        width: 180px;
                        horizontal-alignment: center;
                    }
                }
            }

            // Right block: Settings Gear
            VerticalLayout {
                alignment: center;
                TouchArea {
                    width: 52px;
                    height: 52px;
                    clicked => { root.toggle_settings(); }
                    Image {
                        width: 36px;
                        height: 36px;
                        x: parent.width / 2 - self.width / 2;
                        y: parent.height / 2 - self.height / 2;
                        source: @image-url("assets/img/settings.png");
                        image-fit: contain;
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.compact_mode && root.record_busy && !root.is_recording && !root.system_open;
        x: root.width / 2 - self.width / 2;
        y: root.height - 106px;
        width: 92px;
        height: 24px;
        border-radius: 12px;
        background: rgba(0, 0, 0, 0.62);
        border-width: 1px;
        border-color: rgba(255, 196, 64, 0.42 + 0.36 * root.record_busy_pulse);

        Rectangle {
            x: 10px;
            y: parent.height / 2 - self.height / 2;
            width: 6px + 3px * root.record_busy_pulse;
            height: self.width;
            border-radius: self.width / 2;
            background: rgba(255, 196, 64, 0.45 + 0.55 * root.record_busy_pulse);
        }

        Text {
            text: "SAVING";
            x: 8px;
            width: parent.width - 8px;
            font-size: 11px;
            font-weight: 800;
            color: rgba(255, 196, 64, 0.7 + 0.3 * root.record_busy_pulse);
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }


    Rectangle {
        visible: root.compact_mode && !root.media_open && !root.system_open;
        x: root.settings_open ? root.width - self.width - 10px : root.width + 12px;
        y: 60px;
        width: 188px;
        height: 348px;
        opacity: root.settings_open ? 1 : 0;
        background: rgba(10, 12, 16, 0.90);
        border-radius: 12px;
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.08);
        animate x { duration: 180ms; }
        animate opacity { duration: 120ms; }

        TouchArea {
            width: 100%;
            height: 100%;
            moved => {
                if self.pressed && self.mouse-x > self.pressed-x + 40px {
                    root.toggle_settings();
                }
            }
        }

        VerticalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 12px;

            // Title Bar
            HorizontalLayout {
                alignment: space-between;
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "SETTINGS";
                        font-size: 13px;
                        font-weight: 800;
                        color: #888888;
                        font-family: "Rajdhani";
                    }
                }
                TouchArea {
                    width: 24px;
                    height: 24px;
                    clicked => { root.toggle_settings(); }
                    Text {
                        text: "✕";
                        font-size: 14px;
                        font-weight: 800;
                        color: #ffffff;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-family: "Rajdhani";
                    }
                }
            }

            // Auto/Manual Segmented Toggle
            Rectangle {
                width: 164px;
                height: 36px;
                background: rgba(255, 255, 255, 0.04);
                border-radius: 6px;
                border-width: 1px;
                border-color: rgba(255, 255, 255, 0.06);

                HorizontalLayout {
                    spacing: 0px;
                    TouchArea {
                        clicked => { root.toggle_full_auto(); }
                        width: 82px;
                        Rectangle {
                            width: 100%;
                            height: 100%;
                            border-radius: 5px;
                            background: root.full_auto ? rgba(255, 255, 255, 0.10) : transparent;
                            Text {
                                text: "AUTO";
                                font-size: 12px;
                                font-weight: 800;
                                color: root.full_auto ? #ffffff : #888888;
                                font-family: "Rajdhani";
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    TouchArea {
                        clicked => { root.toggle_full_auto(); }
                        width: 82px;
                        Rectangle {
                            width: 100%;
                            height: 100%;
                            border-radius: 5px;
                            background: !root.full_auto ? rgba(255, 255, 255, 0.10) : transparent;
                            Text {
                                text: "MANUAL";
                                font-size: 12px;
                                font-weight: 800;
                                color: !root.full_auto ? #ffffff : #888888;
                                font-family: "Rajdhani";
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // Settings Grid (FPS, SHUTTER, ISO, WB)
            HorizontalLayout {
                spacing: 8px;

                VerticalLayout {
                    spacing: 8px;

                    TouchArea {
                        clicked => { root.select_setting(0); }
                        Rectangle {
                            width: 78px;
                            height: 56px;
                            border-radius: 8px;
                            background: root.selected_setting == 0 ? rgba(255, 59, 48, 0.2) : rgba(255, 255, 255, 0.04);
                            border-width: 1px;
                            border-color: root.selected_setting == 0 ? #ff3b30 : rgba(255, 255, 255, 0.06);
                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                Text { text: "FPS"; font-size: 13px; font-weight: 800; color: root.selected_setting == 0 ? #ff5c5c : #888888; font-family: "Rajdhani"; horizontal-alignment: center; }
                                Text { text: root.current_fps; font-size: 20px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; }
                            }
                        }
                    }

                    TouchArea {
                        clicked => { root.select_setting(1); }
                        Rectangle {
                            width: 78px;
                            height: 56px;
                            border-radius: 8px;
                            background: root.selected_setting == 1 ? rgba(255, 59, 48, 0.2) : rgba(255, 255, 255, 0.04);
                            border-width: 1px;
                            border-color: root.selected_setting == 1 ? #ff3b30 : rgba(255, 255, 255, 0.06);
                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                Text { text: "SHUTTER"; font-size: 12px; font-weight: 800; color: root.selected_setting == 1 ? #ff5c5c : #888888; font-family: "Rajdhani"; horizontal-alignment: center; }
                                Text { text: root.current_shutter; font-size: 18px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; }
                            }
                        }
                    }
                }

                VerticalLayout {
                    spacing: 8px;

                    TouchArea {
                        clicked => { root.select_setting(2); }
                        Rectangle {
                            width: 78px;
                            height: 56px;
                            border-radius: 8px;
                            background: root.selected_setting == 2 ? rgba(255, 59, 48, 0.2) : rgba(255, 255, 255, 0.04);
                            border-width: 1px;
                            border-color: root.selected_setting == 2 ? #ff3b30 : rgba(255, 255, 255, 0.06);
                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                Text { text: "ISO"; font-size: 13px; font-weight: 800; color: root.selected_setting == 2 ? #ff5c5c : #888888; font-family: "Rajdhani"; horizontal-alignment: center; }
                                Text { text: root.current_iso; font-size: 20px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; }
                            }
                        }
                    }

                    TouchArea {
                        clicked => { root.select_setting(3); }
                        Rectangle {
                            width: 78px;
                            height: 56px;
                            border-radius: 8px;
                            background: root.selected_setting == 3 ? rgba(255, 59, 48, 0.2) : rgba(255, 255, 255, 0.04);
                            border-width: 1px;
                            border-color: root.selected_setting == 3 ? #ff3b30 : rgba(255, 255, 255, 0.06);
                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                Text { text: "WB"; font-size: 13px; font-weight: 800; color: root.selected_setting == 3 ? #ff5c5c : #888888; font-family: "Rajdhani"; horizontal-alignment: center; }
                                Text { text: root.current_wb; font-size: 18px; font-weight: 700; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; }
                            }
                        }
                    }
                }
            }

            // Rec Format selection
            TouchArea {
                clicked => { root.select_setting(4); }
                Rectangle {
                    width: 164px;
                    height: 48px;
                    border-radius: 8px;
                    background: root.selected_setting == 4 ? rgba(255, 59, 48, 0.2) : rgba(255, 255, 255, 0.04);
                    border-width: 1px;
                    border-color: root.selected_setting == 4 ? #ff3b30 : rgba(255, 255, 255, 0.06);

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        alignment: space-between;

                        Text { text: "FORMAT"; font-size: 13px; font-weight: 800; color: root.selected_setting == 4 ? #ff5c5c : #888888; font-family: "Rajdhani"; vertical-alignment: center; }
                        Text { text: root.current_record_format; font-size: 18px; font-weight: 800; color: #ffffff; font-family: "Rajdhani"; vertical-alignment: center; }
                    }
                }
            }

        }
    }

    // Floating View Aids Overlay (Right side of screen in compact mode)
    VerticalLayout {
        visible: root.compact_mode && !root.media_open && !root.settings_open && !root.system_open;
        x: root.width - self.width - 10px;
        y: root.height / 2 - self.height / 2;
        width: 60px;
        spacing: 16px;
        alignment: center;

        // Grid Button
        TouchArea {
            width: 56px;
            height: 56px;
            clicked => { root.grid_visible = !root.grid_visible; }
            Rectangle {
                width: 100%;
                height: 100%;
                border-radius: 28px;
                background: root.grid_visible ? rgba(255, 255, 255, 0.25) : rgba(0, 0, 0, 0.35);
                border-width: 1px;
                border-color: root.grid_visible ? rgba(255, 255, 255, 0.5) : rgba(255, 255, 255, 0.12);
                Image {
                    width: 26px;
                    height: 26px;
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    source: @image-url("assets/img/grid.png");
                    image-fit: contain;
                    opacity: root.grid_visible ? 1 : 0.6;
                }
            }
        }

        // Focus Peaking Button
        TouchArea {
            width: 56px;
            height: 56px;
            clicked => {
                root.focus_peaking_visible = !root.focus_peaking_visible;
                root.toggle_focus_peaking();
            }
            Rectangle {
                width: 100%;
                height: 100%;
                border-radius: 28px;
                background: root.focus_peaking_visible ? rgba(255, 255, 255, 0.25) : rgba(0, 0, 0, 0.35);
                border-width: 1px;
                border-color: root.focus_peaking_visible ? rgba(255, 255, 255, 0.5) : rgba(255, 255, 255, 0.12);
                Image {
                    width: 26px;
                    height: 26px;
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    source: @image-url("assets/img/peak.png");
                    image-fit: contain;
                    opacity: root.focus_peaking_visible ? 1 : 0.6;
                }
            }
        }

        // Zoom Button
        TouchArea {
            width: 56px;
            height: 56px;
            clicked => { root.zoom_magnifier_visible = !root.zoom_magnifier_visible; }
            Rectangle {
                width: 100%;
                height: 100%;
                border-radius: 28px;
                background: root.zoom_magnifier_visible ? rgba(255, 255, 255, 0.25) : rgba(0, 0, 0, 0.35);
                border-width: 1px;
                border-color: root.zoom_magnifier_visible ? rgba(255, 255, 255, 0.5) : rgba(255, 255, 255, 0.12);
                Image {
                    width: 26px;
                    height: 26px;
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    source: @image-url("assets/img/zoom.png");
                    image-fit: contain;
                    opacity: root.zoom_magnifier_visible ? 1 : 0.6;
                }
            }
        }

        // Exposure traffic-light toggle
        TouchArea {
            width: 56px;
            height: 56px;
            clicked => { root.exposure_overlay_visible = !root.exposure_overlay_visible; }
            Rectangle {
                width: 100%;
                height: 100%;
                border-radius: 28px;
                background: root.exposure_overlay_visible ? rgba(255, 255, 255, 0.25) : rgba(0, 0, 0, 0.35);
                border-width: 1px;
                border-color: root.exposure_overlay_visible ? rgba(255, 255, 255, 0.5) : rgba(255, 255, 255, 0.12);
                Image {
                    width: 26px;
                    height: 26px;
                    x: parent.width / 2 - self.width / 2;
                    y: parent.height / 2 - self.height / 2;
                    source: @image-url("assets/img/traffic.png");
                    image-fit: contain;
                    opacity: root.exposure_overlay_visible ? 1 : 0.6;
                }
            }
        }
    }

    Rectangle {
        visible: root.compact_mode && !root.media_open && !root.system_open;
        x: root.settings_open ? 10px : -self.width - 12px;
        y: 60px;
        width: 122px;
        height: 348px;
        opacity: root.settings_open ? 1 : 0;
        background: rgba(10, 12, 16, 0.90);
        border-radius: 12px;
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.08);
        animate x { duration: 180ms; }
        animate opacity { duration: 120ms; }

        TouchArea {
            width: 100%;
            height: 100%;
            moved => {
                if self.pressed && self.pressed-x > self.mouse-x + 40px {
                    root.toggle_settings();
                }
            }
        }

        VerticalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 8px;
            alignment: center;

            // Title of selected setting
            Text {
                text: root.selected_setting_label;
                font-size: 12px;
                font-weight: 800;
                color: #888888;
                font-family: "Rajdhani";
                horizontal-alignment: center;
            }

            // Up adjust button
            TouchArea {
                height: 68px;
                clicked => { root.adjust_setting(-1); }
                Rectangle {
                    width: 100%;
                    height: 100%;
                    border-radius: 8px;
                    background: rgba(255, 255, 255, 0.04);
                    border-width: 1px;
                    border-color: rgba(255, 255, 255, 0.06);

                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        Text { text: "▲"; font-size: 14px; color: #888888; horizontal-alignment: center; }
                        Text { text: root.selected_setting_prev_value; font-size: 16px; font-weight: 700; color: #aaaaaa; font-family: "Rajdhani"; horizontal-alignment: center; }
                    }
                }
            }

            // Active/Current value display
            Rectangle {
                width: 100%;
                height: 108px;
                border-radius: 8px;
                background: rgba(255, 59, 48, 0.15);
                border-width: 1px;
                border-color: #ff3b30;

                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    Text { text: root.selected_setting_value; font-size: 28px; font-weight: 800; color: #ffffff; font-family: "Rajdhani"; horizontal-alignment: center; }
                    Text { text: "CURRENT"; font-size: 12px; font-weight: 800; color: #ff5c5c; font-family: "Rajdhani"; horizontal-alignment: center; }
                }
            }

            // Down adjust button
            TouchArea {
                height: 68px;
                clicked => { root.adjust_setting(1); }
                Rectangle {
                    width: 100%;
                    height: 100%;
                    border-radius: 8px;
                    background: rgba(255, 255, 255, 0.04);
                    border-width: 1px;
                    border-color: rgba(255, 255, 255, 0.06);

                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        Text { text: root.selected_setting_next_value; font-size: 16px; font-weight: 700; color: #aaaaaa; font-family: "Rajdhani"; horizontal-alignment: center; }
                        Text { text: "▼"; font-size: 14px; color: #888888; horizontal-alignment: center; }
                    }
                }
            }
        }
    }

    Rectangle {
        visible: root.compact_mode && root.media_open;
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;
        background: #0a0c10;

        VerticalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 12px;
            padding-bottom: 12px;
            spacing: 12px;

            // Header Bar
            Rectangle {
                width: 100%;
                height: 56px;
                background: transparent;

                HorizontalLayout {
                    alignment: space-between;

                    // Close Button
                    TouchArea {
                        width: 48px;
                        height: 48px;
                        clicked => { root.toggle_media(); }

                        Rectangle {
                            width: 100%;
                            height: 100%;
                            border-radius: 24px;
                            background: rgba(255, 255, 255, 0.08);
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.15);
                            Text { text: "✕"; font-size: 20px; font-weight: 800; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }

                    // Title
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "MEDIA BROWSER";
                            font-size: 18px;
                            font-weight: 800;
                            color: #ffffff;
                            font-family: "Rajdhani";
                            horizontal-alignment: center;
                        }
                    }

                    // Refresh Button
                    TouchArea {
                        width: 48px;
                        height: 48px;
                        clicked => { root.media_refresh(); }
                        enabled: !root.media_loading;

                        Rectangle {
                            width: 100%;
                            height: 100%;
                            border-radius: 24px;
                            background: rgba(255, 255, 255, 0.08);
                            border-width: 1px;
                            border-color: rgba(255, 255, 255, 0.15);
                            Text { text: "↻"; font-size: 22px; font-weight: 700; color: #ffffff; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
            }

            // Single Panel Scrollable Clip List
            Rectangle {
                width: 100%;
                height: root.height - 92px; // 480 - 92 = 388px
                background: rgba(0, 0, 0, 0.20);
                border-radius: 8px;
                border-width: 1px;
                border-color: rgba(255, 255, 255, 0.06);
                clip: true;

                scroll_view := ScrollView {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 8px;
                        alignment: start;

                        for clip_row[index] in root.media_clip_rows : Rectangle {
                            height: 96px;
                            border-radius: 6px;
                            background: root.media_selected_index == index ? rgba(255, 92, 92, 0.08) : rgba(255, 255, 255, 0.03);
                            border-width: 1px;
                            border-color: root.media_selected_index == index ? #ff5c5c : rgba(255, 255, 255, 0.06);

                            // Selected left indicator bar
                            Rectangle {
                                x: 0;
                                y: 0;
                                width: 3px;
                                height: 100%;
                                background: #ff5c5c;
                                visible: root.media_selected_index == index;
                            }

                            // If not selected, a single TouchArea covers the entire row
                            if (root.media_selected_index != index) : TouchArea {
                                clicked => {
                                    let dy = (self.mouse-y - self.pressed-y) / 1px;
                                    let dx = (self.mouse-x - self.pressed-x) / 1px;
                                    if (dy * dy + dx * dx < 100) {
                                        root.media_select(index);
                                    }
                                }
                                moved => {
                                    if (self.pressed) {
                                        let min_y = scroll_view.height - scroll_view.viewport-height;
                                        let max_y = 0px;
                                        if (min_y > 0px) {
                                            scroll_view.viewport-y = 0px;
                                        } else {
                                            scroll_view.viewport-y = max(min_y, min(max_y, scroll_view.viewport-y + self.mouse-y - self.pressed-y));
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    padding-top: 8px;
                                    padding-bottom: 8px;
                                    spacing: 16px;

                                    // Thumbnail preview
                                    Rectangle {
                                        width: 120px;
                                        height: 80px;
                                        border-radius: 4px;
                                        clip: true;
                                        background: #15181c;

                                        Image {
                                            width: 100%;
                                            height: 100%;
                                            source: root.media_clip_thumbs[index];
                                            image-fit: cover;
                                        }
                                    }

                                    // Filename & metadata (flexible width)
                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 4px;

                                        Text {
                                            text: clip_row;
                                            font-size: 18px;
                                            font-weight: 700;
                                            color: #ffffff;
                                            font-family: "Rajdhani";
                                            overflow: elide;
                                        }

                                        Text {
                                            text: "Tap to select options";
                                            font-size: 13px;
                                            color: #666666;
                                            font-family: "Rajdhani";
                                            overflow: elide;
                                        }
                                    }

                                    // Duration badge on the right
                                    VerticalLayout {
                                        alignment: center;
                                        width: 80px;
                                        Text {
                                            text: root.media_clip_durations[index];
                                            font-size: 16px;
                                            font-weight: 700;
                                            color: #ffffff;
                                            font-family: "Rajdhani";
                                            horizontal-alignment: right;
                                        }
                                        Text {
                                            text: "SELECT";
                                            font-size: 11px;
                                            font-weight: 800;
                                            color: #888888;
                                            font-family: "Rajdhani";
                                            horizontal-alignment: right;
                                        }
                                    }
                                }
                            }

                            // If selected, the row is split into Left/Middle selection area and Right Action area
                            if (root.media_selected_index == index) : HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                padding-top: 8px;
                                padding-bottom: 8px;
                                spacing: 16px;

                                TouchArea {
                                    clicked => {
                                        let dy = (self.mouse-y - self.pressed-y) / 1px;
                                        let dx = (self.mouse-x - self.pressed-x) / 1px;
                                        if (dy * dy + dx * dx < 100) {
                                            root.media_select(index);
                                        }
                                    }
                                    moved => {
                                        if (self.pressed) {
                                            let min_y = scroll_view.height - scroll_view.viewport-height;
                                            let max_y = 0px;
                                            if (min_y > 0px) {
                                                scroll_view.viewport-y = 0px;
                                            } else {
                                                scroll_view.viewport-y = max(min_y, min(max_y, scroll_view.viewport-y + self.mouse-y - self.pressed-y));
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 16px;
                                        alignment: start;

                                        // Thumbnail preview
                                        Rectangle {
                                            width: 120px;
                                            height: 80px;
                                            border-radius: 4px;
                                            clip: true;
                                            background: #15181c;

                                            Image {
                                                width: 100%;
                                                height: 100%;
                                                source: root.media_clip_thumbs[index];
                                                image-fit: cover;
                                            }
                                        }

                                        // Filename & detail text
                                        VerticalLayout {
                                            alignment: center;
                                            spacing: 4px;

                                            Text {
                                                text: clip_row;
                                                font-size: 18px;
                                                font-weight: 700;
                                                color: #ffffff;
                                                font-family: "Rajdhani";
                                                overflow: elide;
                                            }

                                            Text {
                                                text: root.media_selected_detail;
                                                font-size: 13px;
                                                color: #aaaaaa;
                                                font-family: "Rajdhani";
                                                overflow: elide;
                                            }
                                        }
                                    }
                                }

                                // Actions when selected
                                VerticalLayout {
                                    alignment: center;
                                    width: 124px;

                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: end;

                                        // Play button
                                        TouchArea {
                                            width: 58px;
                                            height: 48px;
                                            clicked => { root.media_play(index); }
                                            Rectangle {
                                                width: 100%;
                                                height: 100%;
                                                border-radius: 4px;
                                                background: #10b981;

                                                Text {
                                                    text: "▶";
                                                    font-size: 20px;
                                                    color: #ffffff;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }

                                        // Delete button
                                        TouchArea {
                                            width: 58px;
                                            height: 48px;
                                            enabled: !root.media_loading;
                                            clicked => { root.delete_confirm_open = true; }
                                            Rectangle {
                                                width: 100%;
                                                height: 100%;
                                                border-radius: 4px;
                                                background: rgba(255, 92, 92, 0.1);
                                                border-width: 1px;
                                                border-color: #ff5c5c;

                                                Text {
                                                    text: "✕";
                                                    font-size: 20px;
                                                    color: #ff5c5c;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Spinning loading icon in center
                VerticalLayout {
                    visible: root.media_loading && root.media_clip_rows.length == 0;
                    width: parent.width;
                    y: parent.height / 2 - self.height / 2;
                    spacing: 12px;
                    alignment: center;

                    HorizontalLayout {
                        alignment: center;
                        Text {
                            text: "↻";
                            font-size: 32px;
                            color: #ff5c5c;
                            font-family: "Rajdhani";
                            transform-rotation: root.media_loading_pulse * 1deg;
                        }
                    }

                    Text {
                        text: "Scanning recordings...";
                        color: #888888;
                        font-size: 14px;
                        font-family: "Rajdhani";
                        horizontal-alignment: center;
                    }
                }

                // Empty state message
                Text {
                    visible: !root.media_loading && root.media_clip_rows.length == 0;
                    width: parent.width;
                    y: parent.height / 2 - self.height / 2;
                    text: "No clips found";
                    color: #888888;
                    font-size: 14px;
                    font-family: "Rajdhani";
                    horizontal-alignment: center;
                }
            }
        }

        // Delete Confirmation Overlay Modal
        if (root.delete_confirm_open) : Rectangle {
            x: 0;
            y: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);

            TouchArea {
                clicked => { root.delete_confirm_open = false; }
            }

            Rectangle {
                width: 440px;
                height: 250px;
                x: parent.width / 2 - self.width / 2;
                y: parent.height / 2 - self.height / 2;
                background: rgba(20, 10, 10, 0.95);
                border-radius: 12px;
                border-width: 2px;
                border-color: #ff5c5c;

                VerticalLayout {
                    padding: 24px;
                    alignment: space-between;
                    spacing: 16px;

                    VerticalLayout {
                        spacing: 10px;
                        alignment: center;
                        Text {
                            text: "⚠️ DELETE FILE?";
                            font-size: 24px;
                            font-weight: 800;
                            color: #ff5c5c;
                            font-family: "Rajdhani";
                            horizontal-alignment: center;
                        }
                        Text {
                            text: root.media_selected_name;
                            font-size: 16px;
                            font-weight: 600;
                            color: #ffffff;
                            font-family: "Rajdhani";
                            horizontal-alignment: center;
                            overflow: elide;
                        }
                        Text {
                            text: "This action cannot be undone.";
                            font-size: 14px;
                            color: #888888;
                            font-family: "Rajdhani";
                            horizontal-alignment: center;
                        }
                    }

                    HorizontalLayout {
                        spacing: 20px;
                        alignment: center;

                        // Cancel Button
                        TouchArea {
                            width: 170px;
                            height: 56px;
                            clicked => { root.delete_confirm_open = false; }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                border-radius: 8px;
                                background: rgba(255, 255, 255, 0.08);
                                border-width: 1px;
                                border-color: rgba(255, 255, 255, 0.15);
                                Text {
                                    text: "CANCEL";
                                    font-size: 18px;
                                    font-weight: 800;
                                    color: #ffffff;
                                    font-family: "Rajdhani";
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Confirm Button
                        TouchArea {
                            width: 170px;
                            height: 56px;
                            clicked => {
                                root.delete_confirm_open = false;
                                root.media_delete_selected();
                            }
                            Rectangle {
                                width: 100%;
                                height: 100%;
                                border-radius: 8px;
                                background: #ff5c5c;
                                Text {
                                    text: "DELETE";
                                    font-size: 18px;
                                    font-weight: 900;
                                    color: #ffffff;
                                    font-family: "Rajdhani";
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Full screen transparent overlay when screen is blanked to swallow the wake-up tap
    if (root.screen_blanked) : TouchArea {
        x: 0;
        y: 0;
        width: 100%;
        height: 100%;
        clicked => {
            root.interaction_occurred();
        }
    }
}
}

